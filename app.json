{
  "expo": {
    "name": "mobile-meal-advisor",
    "slug": "mobile-meal-advisor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/icons/icon.png",
    "splash": {
      "image": "./app/assets/icons/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./app/assets/icons/playstore.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.behistun.mobilemealadvisor"
    },
    "web": {
      "favicon": "./app/assets/icons/favicon.ico"
    },
    "description": "Mobile Meal Advisor AI",
    "githubUrl": "https://github.com/behistun/mobile-meal-advisor"
  }
}
